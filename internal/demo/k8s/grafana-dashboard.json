{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Per-version HPA scaling metrics for temporal-worker-controller demo",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HPA",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"default\"}",
          "legendFormat": "{{horizontalpodautoscaler}} current",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"default\"}",
          "legendFormat": "{{horizontalpodautoscaler}} desired",
          "refId": "B"
        }
      ],
      "title": "HPA Replicas (current vs desired)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"default\"}",
          "legendFormat": "{{horizontalpodautoscaler}}",
          "refId": "A"
        }
      ],
      "title": "HPA Current Replicas",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Slot Utilization",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "temporal_slot_utilization{temporal_worker_deployment_name=\"default_helloworld\"}",
          "legendFormat": "{{worker_type}} - {{temporal_worker_deployment_name}} / {{temporal_worker_build_id}}",
          "refId": "A"
        }
      ],
      "title": "Activity Slot Utilization per version (0=idle, 1=saturated)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Backlog Count",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "temporal_backlog_count_by_version{task_type=\"Workflow\", temporal_worker_deployment_name=\"default_helloworld\"}",
          "legendFormat": "{{temporal_worker_deployment_name}} / {{temporal_worker_build_id}}",
          "refId": "A"
        }
      ],
      "title": "Workflow Task Backlog per version",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "temporal_backlog_count_by_version{task_type=\"Activity\", temporal_worker_deployment_name=\"default_helloworld\"}",
          "legendFormat": "{{temporal_worker_deployment_name}} / {{temporal_worker_build_id}}",
          "refId": "A"
        }
      ],
      "title": "Activity Task Backlog per version",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Raw Slot Gauges",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "temporal_worker_task_slots_used{worker_type=\"ActivityWorker\", task_queue=\"default/helloworld\"}",
          "legendFormat": "used {{pod}} {{temporal_worker_build_id}}",
          "refId": "A"
        },
        {
          "expr": "temporal_worker_task_slots_available{worker_type=\"ActivityWorker\", task_queue=\"default/helloworld\"}",
          "legendFormat": "available {{pod}} {{temporal_worker_build_id}}",
          "refId": "B"
        }
      ],
      "title": "Activity Slot Gauges (per pod)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "temporal_worker_task_slots_used{worker_type=\"WorkflowWorker\", task_queue=\"default/helloworld\"}",
          "legendFormat": "used {{pod}} {{temporal_worker_build_id}}",
          "refId": "A"
        },
        {
          "expr": "temporal_worker_task_slots_available{worker_type=\"WorkflowWorker\", task_queue=\"default/helloworld\"}",
          "legendFormat": "available {{pod}} {{temporal_worker_build_id}}",
          "refId": "B"
        }
      ],
      "title": "Workflow Slot Gauges (per pod)",
      "type": "timeseries"
    }
